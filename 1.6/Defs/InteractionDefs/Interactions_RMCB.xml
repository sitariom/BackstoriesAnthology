<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Awkward small talk between two pawns who recently failed a romance.
       Its worker only fires for such pairs; RMCB suppresses normal Chitchat
       between them, so they do this instead until they get over it. -->
  <InteractionDef>
    <defName>RMCB_AwkwardChat</defName>
    <label>awkward chat</label>
    <workerClass>ReasonableMoods.InteractionWorker_RMCB_AwkwardChat</workerClass>
    <symbol>Things/Mote/SpeechSymbols/Chitchat</symbol>
    <initiatorThought>RMCB_AwkwardChat</initiatorThought>
    <initiatorXpGainSkill>Social</initiatorXpGainSkill>
    <initiatorXpGainAmount>2</initiatorXpGainAmount>
    <recipientThought>RMCB_AwkwardChat</recipientThought>
    <logRulesInitiator>
      <rulesStrings>
        <li>r_logentry->[INITIATOR_nameDef] and [RECIPIENT_nameDef] exchanged a few awkward words.</li>
        <li>r_logentry->[INITIATOR_nameDef] made stilted small talk with [RECIPIENT_nameDef].</li>
        <li>r_logentry(p=0.6)->[INITIATOR_nameDef] tried to chat with [RECIPIENT_nameDef], but it was awkward.</li>
      </rulesStrings>
    </logRulesInitiator>
  </InteractionDef>

</Defs>
