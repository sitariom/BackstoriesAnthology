<?xml version="1.0" encoding="utf-8"?>
<Defs>


	<!-- fear of fire -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_ChildBurnVictim</defName>
		<title>burn victim</title>
		<titleShort>burned</titleShort>
		<baseDesc>After being terribly burned as a child, [PAWN_nameDef] developed a life-long fear of fire.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>5</commonality>
		<requiredRecords>
			<li>
				<name>TimeOnFire</name>
				<minValue>30000</minValue>
			</li>
		</requiredRecords>
		<skillGains><li><skill>Medicine</skill><amount>2</amount></li></skillGains>
		<workDisables>
			<li>Firefighting</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- juvenile delinquent -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_JuvenileDelinquent</defName>
		<title>juvenile delinquent</title>
		<titleShort>delinquent</titleShort>
		<baseDesc>[PAWN_nameDef] has a troubled childhood. Frequently on the wrong side of the law, [PAWN_pronoun] spent a lot of time in jail.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>5</commonality>
		<recordRatios>
			<li><!-- spent at least 10% of their time in prison -->
				<numerator>TimeAsPrisoner</numerator>
				<denominator>TimeAsColonistOrColonyAnimal</denominator>
				<ratio>0.1</ratio>
			</li>
		</recordRatios>
		<skillGains><li><skill>Melee</skill><amount>2</amount></li><li><skill>Social</skill><amount>2</amount></li><li><skill>Artistic</skill><amount>2</amount></li></skillGains>
		<workDisables>
			<li>Intellectual</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- sole survivor -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_SoleSurvivor</defName>
		<title>sole suvivor</title>
		<titleShort>suvivor</titleShort>
		<baseDesc>Left completely alone, [PAWN_nameDef] was forced to fend for [PAWN_objective]self at a young age.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
			<li>ZCB_NaturalMeditation</li><!-- enables natural meditation focus -->
		</spawnCategories>
		<commonality>100</commonality><!-- this should almost always be picked when the child qualifies -->
		<colonySize>1~1</colonySize>
		<skillGains><li><skill>Medicine</skill><amount>2</amount></li><li><skill>Social</skill><amount>-3</amount></li><li><skill>Intellectual</skill><amount>1</amount></li><li><skill>Crafting</skill><amount>3</amount></li><li><skill>Animals</skill><amount>1</amount></li><li><skill>Plants</skill><amount>3</amount></li><li><skill>Cooking</skill><amount>2</amount></li><li><skill>Mining</skill><amount>1</amount></li><li><skill>Construction</skill><amount>3</amount></li><li><skill>Shooting</skill><amount>2</amount></li><li><skill>Melee</skill><amount>2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- serial killer -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_SerialKiller</defName>
		<title>serial killer</title>
		<titleShort>killer</titleShort>
		<baseDesc>[PAWN_nameDef] spent [PAWN_possessive] childhood learning how to take people apart. [PAWN_possessive] never learned how to put them back together.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>2</commonality>
		<requiredRecords>
			<li>
				<name>KillsHumanlikes</name>
				<minValue>15</minValue>
			</li>
			<li>
				<name>TimesTendedOther</name>
				<maxValue>5</maxValue>
			</li>
		</requiredRecords>
		<skillGains><li><skill>Melee</skill><amount>5</amount></li><li><skill>Social</skill><amount>3</amount></li></skillGains>
		<workDisables>
			<li>Caring</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>



	<!-- morbid curiosity -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_MorbidCuriosity</defName>
		<title>morbid curiosity</title>
		<titleShort>morbid</titleShort>
		<baseDesc>[PAWN_nameDef] was always fascinated by the dead. [PAWN_pronoun] found any excuse to hang around the battlefield, burying the bodies of raiders after stealing their stuff. [PAWN_possessive] peers found this uncomfortable and ostracised [PAWN_objective]. As [PAWN_pronoun] grew older, [PAWN_pronoun] increasingly preferred the company of the dead to that of the living.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>5</commonality>
		<requiredRecords>
			<li>
				<name>BodiesStripped</name>
				<minValue>20</minValue>
			</li>
			<li>
				<name>CorpsesBuried</name>
				<minValue>5</minValue>
			</li>
			<li>
				<name>OperationsPerformed</name>
				<minValue>2</minValue>
			</li>
		</requiredRecords>
		<requiredTraits><li>Psychopath</li></requiredTraits>
		<skillGains><li><skill>Medicine</skill><amount>4</amount></li><li><skill>Intellectual</skill><amount>3</amount></li></skillGains>
		<workDisables>
			<li>Social</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>
	
	
<!-- bookworm -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_BulliedBookworm</defName>
		<title>bullied bookworm</title>
		<titleShort>bookworm</titleShort>
		<baseDesc>As a child, [PAWN_nameDef] never fit in with the other kids. Instead, [PAWN_pronoun] spent [PAWN_possessive] time reading, and occasionally fighting off bullies.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 							<!-- required -->
		</spawnCategories>
		<!-- new tags start here -->
		<commonality>.5</commonality>
		<colonySize>7~99</colonySize>
		<requiredRecords>
			<li>
				<name>ZCB_TimeReading</name>
				<minValue>550000</minValue>			<!-- about 9.15 days -->
			</li>
		</requiredRecords>
		<requiredPassions>
			<li>Intellectual</li>
		</requiredPassions>
		<passionGains>
			<li>
				<skill>Intellectual</skill>
				<level>1</level>
			</li>
		</passionGains>
		<!-- new tags end here-->
		<workDisables>
			<li>Social</li>
		</workDisables>
		<skillGains><li><skill>Intellectual</skill><amount>5</amount></li><li><skill>Melee</skill><amount>2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	
	
	<!-- ================================== HEALTH ================================== -->

	<!-- surgery victim -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_SurgeryVictim</defName>
		<title>surgery victim</title>
		<titleShort>victim</titleShort>
		<baseDesc>[PAWN_nameDef] distrusts doctors, as every hospital visit seems to result in a new artificial part - [PAWN_pronoun] would much prefer to stay intact. When not under the knife, [PAWN_nameDef] enjoyed spending time in nature.\n\nAdds trait: Body purist</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
			<li>ZCB_NaturalMeditation</li>
		</spawnCategories>
		<commonality>1.5</commonality>
		<bodyPartsReplaced>2~999</bodyPartsReplaced>
		<forcedTraits><li>BodyPurist</li></forcedTraits>
		<disallowedTraits><li>Transhumanist</li></disallowedTraits>
		<skillGains><li><skill>Medicine</skill><amount>-3</amount></li><li><skill>Plants</skill><amount>3</amount></li><li><skill>Animals</skill><amount>1</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- amputee -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_Amputee</defName>
		<title>amputee</title>
		<titleShort>amputee</titleShort>
		<baseDesc>[PAWN_nameDef] was distraught the first time [PAWN_pronoun] had to replace one of [PAWN_possessive] natural body parts, but soon grew to appreciate the replacement. [PAWN_pronoun] looks forward to getting more replacement parts for the ones [PAWN_pronoun] is still missing.\n\nAdds trait: Transhumanist</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>1.5</commonality>
		<bodyPartsReplaced>1~999</bodyPartsReplaced>
		<bodyPartsMissing>1~999</bodyPartsMissing>
		<forcedTraits><li>Transhumanist</li></forcedTraits>
		<disallowedTraits><li>BodyPurist</li></disallowedTraits>
		<skillGains><li><skill>Medicine</skill><amount>4</amount></li><li><skill>Intellectual</skill><amount>2</amount></li><li><skill>Plants</skill><amount>-1</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- butchered butcher -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_ButcheredButcher</defName>
		<title>butchered butcher</title>
		<titleShort>butchered</titleShort>
		<baseDesc>Having been under the knife several times, [PAWN_nameDef] is quite comfortable with butchery of both animals and people.\n\nAdds trait: Psychopath</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>1.5</commonality>
		<requiredRecords>
			<li>
				<name>OperationsReceived</name>
				<minValue>2</minValue>
			</li>
		</requiredRecords>
		<bodyPartsReplaced>1~999</bodyPartsReplaced>
		<forcedTraits><li>Psychopath</li></forcedTraits>
		<disallowedTraits><li>BodyPurist</li></disallowedTraits>
		<skillGains><li><skill>Medicine</skill><amount>4</amount></li><li><skill>Cooking</skill><amount>2</amount></li><li><skill>Intellectual</skill><amount>1</amount></li><li><skill>Social</skill><amount>-2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- wimpy transhumanist -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_WimpyTranshumanist</defName>
		<title>wimpy transhumanist</title>
		<titleShort>wimp</titleShort>
		<baseDesc>[PAWN_nameDef] discovered that each new artificial part reduced [PAWN_possessive] ability to feel pain. [PAWN_pronoun] made it [PAWN_possessive] mission to replace as much as possible of [PAWN_possessive] weak flesh.\n\nAdds trait: Transhumanist</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>3</commonality>
		<bodyPartsReplaced>1~999</bodyPartsReplaced>
		<requiredTraits><li>Wimp</li></requiredTraits>
		<forcedTraits><li>Transhumanist</li></forcedTraits>
		<disallowedTraits><li>BodyPurist</li></disallowedTraits>
		<skillGains><li><skill>Medicine</skill><amount>3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- transhumanist -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_Transhumanist</defName>
		<title>transhumanist</title>
		<titleShort>transhumanist</titleShort>
		<baseDesc>[PAWN_nameDef] felt that [PAWN_possessive] arficial parts were improvements over [PAWN_possessive] natural flesh.\n\nAdds trait: Transhumanist</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>2</commonality>
		<bodyPartsReplaced>2~999</bodyPartsReplaced>
		<forcedTraits><li>Transhumanist</li></forcedTraits>
		<disallowedTraits><li>BodyPurist</li></disallowedTraits>
		<skillGains><li><skill>Medicine</skill><amount>5</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>



</Defs>