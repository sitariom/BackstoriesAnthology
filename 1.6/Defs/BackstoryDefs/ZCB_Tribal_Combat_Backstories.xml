<Defs>

<!-- child warrior -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_ChildWarrior</defName>
		<title>child warrior</title>
		<titleShort>warrior</titleShort>
		<baseDesc>[PAWN_nameDef] was exposed to the harsh realities of battle at a young age. 
\n[PAWN_pronoun] is skilled in combat, but the trauma has stunted [PAWN_possessive] social skills.</baseDesc>
		<slot>Childhood</slot>
		<maxTechLevel>Neolithic</maxTechLevel>
		<spawnCategories>
			<li>ZCB</li> 							<!-- required -->
			<li>ZCB_NaturalMeditation</li> 			<!-- enables natural meditation focus -->
		</spawnCategories>
		<commonality>3</commonality>
		<requiredRecords>
			<li>
				<name>KillsHumanlikes</name>
				<minValue>2</minValue>
			</li>
			<li>
