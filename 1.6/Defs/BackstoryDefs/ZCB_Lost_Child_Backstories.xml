<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- Backstories for children not originally from the colony -->

	<!-- lost child -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_LostChild</defName>
		<title>lost boy</title>
		<titleFemale>lost girl</titleFemale>
		<titleShort>lost</titleShort>
		<baseDesc>Much of [PAWN_possessive] early childhood is a mystery, but [PAWN_nameDef] came of age in our colony.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<requiredRecords>
			<li>
				<name>TimeAsColonistOrColonyAnimal</name>
				<maxValue>3000000</maxValue>			<!-- one year -->
			</li>
		</requiredRecords>
		<skillGains><li><skill>Cooking</skill><amount>1</amount></li><li><skill>Melee</skill><amount>2</amount></li><li><skill>Crafting</skill><amount>2</amount></li><li><skill>Plants</skill><amount>-2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	

	<!-- builder -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_Builder</defName>
		<title>builder</title>
		<titleShort>builder</titleShort>
		<baseDesc>After [PAWN_possessive] parents abandoned [PAWN_objective], [PAWN_pronoun] was taken in by pirates and forced to fight. Later [PAWN_pronoun] jonied [PAWN_factionName] and discovered a passion for building, quickly signing up to help renovate [PAWN_possessive] new home.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li>
		</spawnCategories>
		<commonality>5</commonality>
		<requiredRecords>
			<li>
				<name>TimeAsColonistOrColonyAnimal</name>
				<maxValue>4000000</maxValue>			<!-- 1.3 years -->
			</li>
			<li>
				<name>ThingsConstructed</name>
				<minValue>20</minValue>
			</li>
			<li>
				<name>CellsMined</name>
				<maxValue>5</maxValue>
			</li>
		</requiredRecords>
		<requiredPassions>
			<li>Construction</li>
		</requiredPassions>
		<skillGains><li><skill>Melee</skill><amount>2</amount></li><li><skill>Construction</skill><amount>4</amount></li><li><skill>Mining</skill><amount>2</amount></li></skillGains>
		<workDisables>
			<li>Animals</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>



</Defs>