<?xml version="1.0" encoding="utf-8"?>
<Defs>


<!-- tribal orphan -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_TribeOrphan</defName>
		<title>orphan</title>
		<titleShort>orphan</titleShort>
		<baseDesc>Growing up an orphan in a small tribe, [PAWN_nameDef] loved proving [PAWN_objective]self in a fight. [PAWN_pronoun] also learned the basics of gathering edible plants and cooking them into delicious meals, so that [PAWN_pronoun] would never go hungry again.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 							<!-- required -->
			<li>ZCB_NaturalMeditation</li> 			<!-- enables natural meditation focus -->
		</spawnCategories>
		
		<!-- new tags start here -->
		<commonality>10</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<father>Absent, Dead</father>
		<mother>Absent, Dead</mother>
		<colonySize>1~8</colonySize>
		
		<requiredSkills>
			<li>
				<name>Cooking</name>
				<minValue>3</minValue>
			</li>
			<li>
				<name>Plants</name>
				<minValue>3</minValue>
			</li>
		</requiredSkills>
		
		<requiredPassions>
			<li>Melee</li>
		</requiredPassions>
		<!-- new tags end here-->
		
		<skillGains><li><skill>Melee</skill><amount>3</amount></li><li><skill>Cooking</skill><amount>3</amount></li><li><skill>Plants</skill><amount>2</amount></li><li><skill>Intellectual</skill><amount>-3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


<!-- tribal orphan -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_TribeOrphan2</defName>
		<title>orphan</title>
		<titleShort>orphan</titleShort>
		<baseDesc>[PAWN_nameDef] lost [PAWN_possessive] parents at a young age. [PAWN_pronoun] found solace caring for the livestock and other animals of [PAWN_possessive] tribe.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 							<!-- required -->
			<li>ZCB_NaturalMeditation</li> 			<!-- enables natural meditation focus -->
		</spawnCategories>
		
		<!-- new tags start here -->
		<commonality>4</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<father>Absent, Dead</father>
		<mother>Absent, Dead</mother>
		
		<requiredPassions>
			<li>Animals</li>
		</requiredPassions>
		<!-- new tags end here-->
		
		<skillGains><li><skill>Animals</skill><amount>4</amount></li><li><skill>Medicine</skill><amount>1</amount></li><li><skill>Artistic</skill><amount>-3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


</Defs>