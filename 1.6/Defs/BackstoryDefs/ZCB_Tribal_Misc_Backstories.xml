<?xml version="1.0" encoding="utf-8"?>
<Defs>


<!-- happy go lucky -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_HappyGoLucky2</defName>
		<title>happy go lucky</title>
		<titleShort>happy</titleShort>
		<baseDesc>[PAWN_nameDef] had a peaceful childhood, shielded from hardship by [PAWN_possessive] tribe. [PAWN_possessive] childhood had little strife, and [PAWN_pronoun] spent [PAWN_possessive] time daydreaming and drawing.</baseDesc>
		<slot>Childhood</slot>
		<maxTechLevel>Neolithic</maxTechLevel>
		<spawnCategories>
			<li>ZCB</li> 							
			<li>ZCB_NaturalMeditation</li> 			<!-- enables natural meditation focus -->
		</spawnCategories>
		<!-- new tags start here -->
		<commonality>2</commonality>
		<father>Present</father>
		<mother>Present</mother>
		<colonySize>1~99</colonySize>
		<requiredRecords>
			<li>	<!-- max 6 hours spent drafted -->
				<name>TimeDrafted</name>
				<maxValue>15000</maxValue>
			</li>
			<li>		
				<name>Kills</name>
				<maxValue>0</maxValue>
			</li>
			<li>		
				<name>ShotsFired</name>
				<maxValue>8</maxValue>
			</li>
		</requiredRecords>
		<!-- new tags end here-->
		<skillGains><li><skill>Shooting</skill><amount>-2</amount></li><li><skill>Melee</skill><amount>-2</amount></li><li><skill>Artistic</skill><amount>4</amount></li><li><skill>Social</skill><amount>3</amount></li><li><skill>Intellectual</skill><amount>3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


	<!-- dreamer -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_TribalDreamer</defName>
		<title>dreamer</title>
		<titleShort>dreamer</titleShort>
		<baseDesc>Always running off to watch the clouds, [PAWN_nameDef] spent hardly any time at home. [PAWN_pronoun] never learned how to interact with people, but whenever forced to do chores would come up with ways to do them faster than anyone else.</baseDesc>
		<slot>Childhood</slot>
		<maxTechLevel>Neolithic</maxTechLevel>
		<spawnCategories>
			<li>ZCB</li> 							
			<li>ZCB_NaturalMeditation</li> 			<!-- enables natural meditation focus -->
		</spawnCategories>
		<!-- new tags start here -->
		<commonality>.4</commonality> 			<!-- not a lot of requirements to get this one, so the commonality is low -->
		<requiredRecords>
			<li>
				<name>ThingsCrafted</name>
				<minValue>100</minValue>
			</li>
		</requiredRecords>
		<disallowedPassions>
			<li>Social</li>
		</disallowedPassions>
		<!-- new tags end here-->
		<skillGains><li><skill>Social</skill><amount>-3</amount></li><li><skill>Intellectual</skill><amount>3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


<!-- animal trainer -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_AnimalTrainer</defName>
		<title>animal trainer</title>
		<titleShort>trainer</titleShort>
		<baseDesc>[PAWN_nameDef] has a way with animals, and has been training them since the moment [PAWN_pronoun] was old enough. Why carry firewood when a dog can do it for you?</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
			<li>ZCB_NaturalMeditation</li>
		</spawnCategories>
		<commonality>.7</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<requiredPassions>
			<li>Animals</li>
		</requiredPassions>
		<workDisables>
			<li>ManualDumb</li>
		</workDisables>
		<skillGains><li><skill>Animals</skill><amount>5</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	
	
<!-- tribal bookworm -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_TribalBookworm</defName>
		<title>tribal bookworm</title>
		<titleShort>bookworm</titleShort>
		<baseDesc>Despite growing up in a primitive tribe, [PAWN_nameDef] spent as much of [PAWN_possessive] time reading as possible. [PAWN_pronoun] loved getting lost in the worlds of stories, and dreaming about what might be.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
			<li>ZCB_NaturalMeditation</li>
		</spawnCategories>
		<commonality>1</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<requiredRecords>
			<li>
				<name>ZCB_TimeReading</name>
				<minValue>560000</minValue>			<!-- about 9.3 days -->
			</li>
		</requiredRecords>
		<passionGains>
			<li>
				<key>Intellectual</key>
				<value>1</value>
			</li>
		</passionGains>
		<skillGains><li><skill>Intellectual</skill><amount>4</amount></li><li><skill>Artistic</skill><amount>1</amount></li><li><skill>Animals</skill><amount>-2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	
		
<!-- budding adventurer -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_BuddingAdventurer</defName>
		<title>budding adventurer</title>
		<titleShort>adventurer</titleShort>
		<baseDesc>[PAWN_nameDef] grew up reading all sorts of adventure stories. [PAWN_pronoun] dreamed of one day going on [PAWN_pronoun] own adventures, and writing bestselling books of [PAWN_possessive] exploits.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
			<li>ZCB_NaturalMeditation</li>
		</spawnCategories>
		<commonality>1</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<requiredRecords>
			<li>
				<name>ZCB_TimeReading</name>
				<minValue>540000</minValue>			<!-- about 9 days -->
			</li>
		</requiredRecords>
		<requiredPassions>
			<li>Intellectual</li>
			<li>Melee</li>
		</requiredPassions>
		<skillGains><li><skill>Intellectual</skill><amount>4</amount></li><li><skill>Melee</skill><amount>4</amount></li><li><skill>Shooting</skill><amount>2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	
	
	<!-- experimenter -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_Experimenter</defName>
		<title>experimenter</title>
		<titleShort>experimenter</titleShort>
		<baseDesc>[PAWN_nameDef] loved to learn, but had little access to books. Instead, [PAWN_pronoun] turned [PAWN_possessive] attention to practical experiments.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
			<li>ZCB_NaturalMeditation</li>
		</spawnCategories>
		<commonality>.8</commonality>
		<maxTechLevel>Neolithic</maxTechLevel>
		<requiredRecords>
			<li>
				<name>ZCB_TimeReading</name>
				<maxValue>354000</maxValue>			<!-- about 5.9 days -->
			</li>
		</requiredRecords>
		<requiredPassions>
			<li>Intellectual</li>
		</requiredPassions>
		<skillGains><li><skill>Intellectual</skill><amount>3</amount></li><li><skill>Medicine</skill><amount>1</amount></li><li><skill>Plants</skill><amount>2</amount></li><li><skill>Crafting</skill><amount>2</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>
	
	
