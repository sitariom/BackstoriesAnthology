<!-- kitchen aid -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_KitchenAid</defName>
		<title>kitchen aid</title>
		<titleShort>cook</titleShort>
		<baseDesc>[PAWN_nameDef] helped in the kitchen, chopping vegetables and preparing simple meals for the colony. [PAWN_pronoun] learned how to make delicious meals efficiently while avoiding food poisoning.</baseDesc>
		<slot>Childhood</slot>
		<commonality>2</commonality>
		<minTechLevel>Medieval</minTechLevel>
		<spawnCategories>
			<li>ZCB</li> 
		</spawnCategories>
		<requiredSkills>
			<li>
				<name>Cooking</name>
				<minValue>7</minValue>
			</li>
			<li>
				<name>Construction</name>
				<maxValue>5</maxValue>
			</li>
		</requiredSkills>
		<skillGains><li><skill>Cooking</skill><amount>4</amount></li><li><skill>Plants</skill><amount>1</amount></li><li><skill>Construction</skill><amount>-3</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


