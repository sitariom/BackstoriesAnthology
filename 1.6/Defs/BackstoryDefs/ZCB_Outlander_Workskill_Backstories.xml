<?xml version="1.0" encoding="utf-8"?>
<Defs>

<!-- child nurse -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_ChildNurse</defName>
		<title>child nurse</title>
		<titleShort>nurse</titleShort>
		<baseDesc>[PAWN_nameDef] grew up taking care of the sick and injured.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
		</spawnCategories>
		<minTechLevel>Medieval</minTechLevel>
		<requiredRecords>
			<li>
				<name>TimesTendedOther</name>
				<minValue>30</minValue>
			</li>
		</requiredRecords>
		<skillGains><li><skill>Medicine</skill><amount>3</amount></li><li><skill>Social</skill><amount>1</amount></li><li><skill>Melee</skill><amount>-1</amount></li><li><skill>Shooting</skill><amount>-1</amount></li></skillGains>
	</UnifiedBackstories.ZCBackstoryDef>


<!-- child doctor -->
	<UnifiedBackstories.ZCBackstoryDef>
		<defName>UB_ZCB_ChildDoctor</defName>
		<title>child doctor</title>
		<titleShort>doctor</titleShort>
		<baseDesc>[PAWN_nameDef] was a medical prodigy, caring for the sick and injured and even performing surgery at a young age. Having seen so many injuries, [PAWN_pronoun] abhors violence.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>ZCB</li> 
		</spawnCategories>
		<commonality>3</commonality>
		<minTechLevel>Medieval</minTechLevel>
		<requiredRecords>
			<li>
				<name>OperationsPerformed</name>
				<minValue>1</minValue>
			</li>
		</requiredRecords>
		<requiredPassions>
			<li>Medicine</li>
		</requiredPassions>
		<skillGains><li><skill>Medicine</skill><amount>5</amount></li><li><skill>Social</skill><amount>1</amount></li></skillGains>
		<workDisables>
			<li>Violent</li>
		</workDisables>
	</UnifiedBackstories.ZCBackstoryDef>



