<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<PlaceDef MayRequire="ludeon.rimworld.ideology">
    <defName>UB_Seal_Place_Hiraeth</defName>
    <!-- A wandering planetoid devoid of atmosphere, pulled away from its star some thousands of years ago by an unknown event. Its only light source is now too far in the sky, and the ruined surface is cast into an eternal darkness. A cult dedicated to the shadows strives deep inside the underground ruins of Hiraeth, and praises the darkness for the light is treacherous. -->
    <tags>
      <li>OriginSpacer</li>
    </tags>
    <placeRules>
      <include>
        <li>PlaceMakerCommon</li>
      </include>
      <rulesStrings>
        <li>place_name->Hiraeth</li>
        <li>place_adjective->Hiraeth</li>
        <li>place_summary->sunless wandering planetoid</li>
        <li>place_community->endless galleries</li>
        <li>place_community->underground cathedral</li>
        <li>place_community->mushroom farm</li>
        <li>place_powerCenter->ancient stone citadel</li>
        <li>place_job->underground exporer</li>
        <li>place_job->shieldbearer</li>
        <li>place_job->priest</li>
        <li>place_personalWeapon->greatsword</li>
        <li>place_personalWeapon->sacrificial dagger</li>
        <li>place_massWeapon->a hord of mutated horrors from the depths</li> <!-- Humanoid creatures adapted to underground life -->
        <li>place_massWeapon->unnatural powers</li>
		    <li>place_foeLeader->heretic archbishop</li>
		    <li>place_foeLeader->corrupted psycaster</li>
        <li>place_foeSoldiers->knights</li>
      </rulesStrings>
    </placeRules>
  </PlaceDef>

<PlaceDef MayRequire="ludeon.rimworld.ideology">
    <defName>UB_Seal_Place_Zadamentine</defName>
    <!-- A desert planet where the dunes are made of trillions of archites psychically resonating in a network, each being a neuron of a mysterious archotech. Water is scarce, but civilization is somehow present and has attuned with the planet. -->  
    <tags>
      <li>OriginTribal</li>
      <li>OriginSpacer</li>
    </tags>
    <placeRules>
      <include>
        <li>PlaceMakerCommon</li>
      </include>
      <rulesStrings>
        <li>place_name->Zadamentine</li>
        <li>place_adjective->Zadamentian</li>
        <li>place_summary->archotech dune-world</li>
        <li>place_community->great city carved in stone</li> <!-- Petra style -->
        <li>place_community->psychic monastery</li>
        <li>place_community->caravanserai</li>
        <li>place_powerCenter->folded city</li> <!-- Prefab city folded on itself to carry it before installing it on a planet -->
        <li>place_job->water seeker</li>
        <li>place_job->archoshaman</li>
        <li>place_job->dune speaker</li>
        <li>place_job->caravaneer</li>
        <li>place_personalWeapon->takouba</li> <!-- Sahelian sword -->
        <li>place_personalWeapon->psychic powers</li>
        <li>place_massWeapon->an angered [zadamentineArchotechMonster]</li>
        <li>place_massWeapon->a summoned [zadamentineArchotechMonster]</li>
        <li>place_foeLeader->megacorp operative</li>
        <li>place_foeSoldiers->marines</li>

        <li>zadamentineArchotechMonster->archite djinn</li>
        <li>zadamentineArchotechMonster->living dune</li>

      </rulesStrings>
    </placeRules>
  </PlaceDef>

<PlaceDef MayRequire="ludeon.rimworld.ideology">
    <defName>UB_Seal_Place_AlphaTarascon</defName>
    <!-- A planetary system far away from any civilization center, containing only a few deadworlds. Some proto-states have emerged and are in a constant war between each other, while civilians try to survive the day-to-day life in pressurized habitats and derelict space stations. s-->
    <tags>
      <li>OriginSpacer</li>
    </tags>
    <placeRules>
      <include>
        <li>PlaceMakerCommon</li>
      </include>
      <rulesStrings>
        <li>place_name->α Tarascon</li>
        <li>place_adjective->Tarascan</li>
        <li>place_summary->war-torn system</li>
        <li>place_community->derelict space station</li>
        <li>place_community->deadworld underground habitat</li>
        <li>place_community->old orbital hydroponic station</li>
        <li>place_community->deserted deadworld fortress</li>
        <li>place_powerCenter->Lagrange bastion</li>
        <li>place_job->hull engineer</li>
        <li>place_job->soldier</li>
        <li>place_job->station-dweller</li>
        <li>place_personalWeapon->compressed air rifle</li> <!-- A short range gun to fight in pressurized environments -->
        <li>place_personalWeapon->hullpiercer gun</li>
        <li>place_massWeapon->Johnson-Tanaka orbital canon</li> <!-- Makes steel shells go zoom at near light velocity -->
        <li>place_foeLeader->despotic officer</li>
        <li>place_foeSoldiers->E.V.A marines</li>
        <li>place_foeSoldiers->orbital mechs</li>
        <li>place_foeSoldiers->space mercenaries</li>
      </rulesStrings>
    </placeRules>
  </PlaceDef>

<PlaceDef MayRequire="ludeon.rimworld.ideology">
    <defName>UB_Seal_Place_Litollia</defName>
    <!-- A low-population glitterworld with atolls and islands lost in a planet-wide ocean. Great cities exist among spiralling coral towers, in a breathtaking paradise. The biosphere is made of artificial species, genetically engineered and often part of the landscape. The weather and sky is controlled by a network of sky-painting satellites. -->
    <tags>
      <li>OriginSpacer</li>
    </tags>
    <placeRules>
      <include>
        <li>PlaceMakerCommon</li>
      </include>
      <rulesStrings>
        <li>place_name->Litollia</li>
        <li>place_adjective->Litollian</li>
        <li>place_summary->oceanic glitterworld</li>
        <li>place_community->pyramidal habitation megaplex</li>
        <li>place_community->paradisiac atoll village</li>
        <li>place_community->towering coral resort</li>
        <li>place_community->pelagic city</li>
        <li>place_powerCenter->island capitol</li>
        <li>place_job->sea navigator</li>
        <li>place_job->aquarium diver</li>
        <li>place_job->amphibic mechanoid overseer</li>
        <li>place_job->wilderness guide</li>
        <li>place_job->performer</li>
        <li>place_personalWeapon->plasma saber</li>
        <li>place_personalWeapon->beam rifle</li>
        <li>place_personalWeapon->torpedo launcher</li>
        <li>place_massWeapon->a hacked sky painter satellite</li>
		    <li>place_foeLeader->space pirate lord</li>
        <!-- <li>place_foeSoldiers->pirates</li> -->
        <li>place_foeSoldiers->benthic mechanoids</li>
      </rulesStrings>
    </placeRules>
  </PlaceDef>

</Defs>