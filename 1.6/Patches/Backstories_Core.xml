    <xpath>Defs/BackstoryDef[defName="Novelist7"]/workDisables</xpath>
  </li><!-- charity worker: compassionate, not a sworn pacifist --><li Class="PatchOperationRemove">
    <xpath>Defs/BackstoryDef[defName="CharityWorker36"]/workDisables</xpath>
  </li><li Class="PatchOperationAdd">
    <xpath>Defs/BackstoryDef[defName="CharityWorker36"]/skillGains</xpath>
    <value><Melee>-2</Melee><Shooting>-2</Shooting></value>
  </li><!-- glitterworld officer: a soldier can carry crates --><li Class="PatchOperationRemove">
    <xpath>Defs/BackstoryDef[defName="GlitterworldOfficer60"]/workDisables</xpath>
  </li><!-- biosphere manager: robots cooked and crafted; they never did, so they're bad at it --><li Class="PatchOperationRemove">
