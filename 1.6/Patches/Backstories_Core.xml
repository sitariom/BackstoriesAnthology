  </li><li Class="PatchOperationAdd">
    <xpath>Defs/BackstoryDef[defName="Sculptor63"]/skillGains</xpath>
    <value><Cooking>-3</Cooking></value>
  </li><!-- Medieval: uneducated is not the same as incapable of learning --><!-- medieval farm oaf --><li Class="PatchOperationRemove">
