  </li><li Class="PatchOperationAdd">
    <xpath>Defs/BackstoryDef[defName="BiosphereManager95"]/skillGains</xpath>
    <value><Crafting>-3</Crafting><Cooking>-3</Cooking></value>
  </li><!-- VR designer --><li Class="PatchOperationRemove">
    <xpath>Defs/BackstoryDef[defName="VRDesigner87"]/workDisables</xpath>
