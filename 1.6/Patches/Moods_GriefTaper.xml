<Operation Class="UnifiedBackstories.PatchOperation_IfSetting"><setting>griefTaper</setting><operations><!-- ============================================================
       Grief that tapers instead of vanishing.
       Vanilla: flat -X for 30 days, then a cliff to zero.
       Now: 1.5x sharper on day one, fading linearly to nothing
       over 40 days (lerpMoodToZero). Total grief is comparable;
       the shape is human. Composes with All Memories Fade,
       which multiplies these base values globally.
       ============================================================ --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[@Name="DeathMemoryFamily"]/durationDays</xpath>
    <value><durationDays>40</durationDays></value>
  </li><li Class="PatchOperationAdd">
    <xpath>Defs/ThoughtDef[@Name="DeathMemoryFamily"]</xpath>
    <value><lerpMoodToZero>true</lerpMoodToZero></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[@Name="LostMemoryFamily"]/durationDays</xpath>
    <value><durationDays>40</durationDays></value>
  </li><li Class="PatchOperationAdd">
    <xpath>Defs/ThoughtDef[@Name="LostMemoryFamily"]</xpath>
    <value><lerpMoodToZero>true</lerpMoodToZero></value>
  </li><!-- Family member Died : base values x1.5 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="MySonDied"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-30</baseMoodEffect></value>
