<Operation Class="UnifiedBackstories.PatchOperation_IfSetting"><setting>moodRebalance</setting><operations><!-- ============================================================
       Reasonable Moods - relationships and mood outliers.
       Physiological suffering (starvation, pain, psychic drones,
       temperature) is untouched. Social betrayals are rescaled so
       severity matches the deed, and trivial inconveniences no
       longer hit like disasters.
       ============================================================ --><!-- ===== Relationship opinion rebalance =====
       Vanilla: cheating = -70, selling someone's loved one to slavers = -10.
       New scale: selling a loved one (-60) is a profound betrayal, worse than
       cheating (-50). Divorce (-45) and breakups (-30) hurt, but less than
       someone literally killing your lover (-50). --><!-- selling my loved one: -10 -> -60 opinion, -10 -> -20 mood --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="SoldMyLovedOne"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-60</baseOpinionOffset></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="SoldMyLovedOne"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-20</baseMoodEffect></value>
  </li><!-- cheated on me: -70 -> -50 opinion (mood stays -20) --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="CheatedOnMe"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-50</baseOpinionOffset></value>
  </li><!-- divorced me: -70 -> -45 opinion, mood -20 -> -15 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="DivorcedMe"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-45</baseOpinionOffset></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="DivorcedMeMood"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-15</baseMoodEffect></value>
  </li><!-- broke up with me: -50 -> -30 opinion (a breakup should not equal your lover being killed), mood -15 -> -10 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="BrokeUpWithMe"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-30</baseOpinionOffset></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="BrokeUpWithMeMood"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-10</baseMoodEffect></value>
  </li><!-- rejected my proposal: -30 -> -20 opinion, mood -18 -> -10 (disappointment, not months of despair) --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="RejectedMyProposal"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-20</baseOpinionOffset></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="RejectedMyProposalMood"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-10</baseMoodEffect></value>
  </li><!-- failed to romance me: -15 -> -8 (being asked out is not an offense) --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="FailedRomanceAttemptOnMe"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-8</baseOpinionOffset></value>
  </li><!-- killed my kin: -15 -> -25 (they killed your family member!) --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="KilledMyKin"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-25</baseOpinionOffset></value>
  </li><!-- killed my bonded animal: -10 -> -20 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="KilledMyBondedAnimal"]/stages/li/baseOpinionOffset</xpath>
    <value><baseOpinionOffset>-20</baseOpinionOffset></value>
  </li><!-- ===== Horrors that were shrugged off ===== --><!-- a colonist had organs harvested and everyone was mildly annoyed: -5 -> -8 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="KnowColonistOrganHarvested"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-8</baseMoodEffect></value>
  </li><!-- ===== Minor inconveniences that hit like disasters ===== --><!-- kibble: unpleasant, but -12 equals ravenous hunger. -> -6 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="AteKibble"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-6</baseMoodEffect></value>
  </li><!-- dead man's clothes on a post-apocalyptic planet: -14 -> -6 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="DeadMansApparel"]/stages/li/baseMoodEffect</xpath>
    <value><baseMoodEffect>-6</baseMoodEffect></value>
  </li><!-- boredom is depressing, not disastrous: -20/-10/-5 -> -14/-8/-4 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedJoy"]/stages/li[label="recreation-starved"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-14</baseMoodEffect></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedJoy"]/stages/li[label="recreation-deprived"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-8</baseMoodEffect></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedJoy"]/stages/li[label="recreation unfulfilled"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-4</baseMoodEffect></value>
  </li><!-- an ugly floor is not a crisis: -15/-10/-5 -> -10/-6/-3 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedBeauty"]/stages/li[label="hideous environment"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-10</baseMoodEffect></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedBeauty"]/stages/li[label="ugly environment"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-6</baseMoodEffect></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedBeauty"]/stages/li[label="unsightly environment"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-3</baseMoodEffect></value>
  </li><!-- a small bedroom: -10/-5 -> -6/-3 --><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedRoomSize"]/stages/li[label="confined interior"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-6</baseMoodEffect></value>
  </li><li Class="PatchOperationReplace">
    <xpath>Defs/ThoughtDef[defName="NeedRoomSize"]/stages/li[label="cramped interior"]/baseMoodEffect</xpath>
    <value><baseMoodEffect>-3</baseMoodEffect></value>
  </li></operations></Operation></Patch>
