<?xml version="1.0" encoding="utf-8"?>
<Patch>

  

  

<Operation Class="UnifiedBackstories.PatchOperation_IfSetting"><setting>capableBackstories</setting><operations><!-- Cybranian - Backstories+ compat.
       This mod attaches arbitrary chore disables (Cleaning, PlantWork, Animals, Mining...)
       to nearly every profession. None are justified by the stories, so all work disables
       are removed wholesale, then the handful that ARE earned by trauma or conviction are
       re-added below. --><li Class="PatchOperationFindMod">
    <mods>
      <li>Cybranian - Backstories+</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

        <!-- Wipe every work disable in the mod -->
        <li Class="PatchOperationRemove">
          <xpath>Defs/BackstoryDef[starts-with(defName,"Backstories_Adulthood_") or starts-with(defName,"Backstories_Childhood_")]/workDisables</xpath>
        </li>

        <!-- Re-add the earned ones -->

        <!-- terror attack victim: "forever changed psyche" -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Victim"]</xpath>
          <value><workDisables><li>Violent</li></workDisables></value>
        </li>

        <!-- sectarian: lost their identity in a brutal paramilitary sect -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Sectarian"]</xpath>
          <value><workDisables><li>Social</li></workDisables></value>
        </li>

        <!-- terrorist: "dissolved his personality in pools of blood" -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Terrorist"]</xpath>
          <value><workDisables><li>Caring</li></workDisables></value>
        </li>

        <!-- serial killer / maniac: ruthless psychopaths -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Serial_Killer"]</xpath>
          <value><workDisables><li>Social</li></workDisables></value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Maniac"]</xpath>
          <value><workDisables><li>Social</li></workDisables></value>
        </li>

        <!-- ruthless predator: "nothing human left in him" -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Ruthless_Predator"]</xpath>
          <value><workDisables><li>Social</li><li>Caring</li></workDisables></value>
        </li>

        <!-- monk and clergyman: religious nonviolence -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Monk"]</xpath>
          <value><workDisables><li>Violent</li></workDisables></value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Adulthood_Clergyman"]</xpath>
          <value><workDisables><li>Violent</li></workDisables></value>
        </li>

        <!-- living shield: used as a human shield by their own father -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Living_Shield"]</xpath>
          <value><workDisables><li>Violent</li></workDisables></value>
        </li>

        <!-- broken child: "could not stand the horrors of the trench war" -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Broken_Child"]</xpath>
          <value><workDisables><li>Violent</li><li>Social</li></workDisables></value>
        </li>

        <!-- prisoner: "destroys his personality forever" -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Prisoner"]</xpath>
          <value><workDisables><li>Social</li></workDisables></value>
        </li>

        <!-- Mowgli: raised by a panther -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Mowgli"]</xpath>
          <value><workDisables><li>Intellectual</li><li>Social</li><li>Caring</li></workDisables></value>
        </li>

        <!-- insane child: disease, killed a dozen tribespeople -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Insane_Child"]</xpath>
          <value><workDisables><li>Social</li><li>Caring</li></workDisables></value>
        </li>

        <!-- peaceful demonstrator: pacifist conviction, jailed for it -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Backstories_Childhood_Peaceful_Demonstrator"]</xpath>
          <value><workDisables><li>Violent</li></workDisables></value>
        </li>

      </operations>
    </match>
  </li></operations></Operation></Patch>
