<?xml version="1.0" encoding="utf-8"?>
<Patch>
  
  
<Operation Class="UnifiedBackstories.PatchOperation_IfSetting"><setting>capableBackstories</setting><operations><!-- Tribal Backstories compat. Kept: CapturedPillager (redemption vow), BrokenSlave (explicit trauma), CrazedWarrior (psychotic break), RaisedByWolves (feral child). --><li Class="PatchOperationFindMod">
    <mods>
      <li>Tribal Backstories</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationRemove">
          <xpath>Defs/BackstoryDef[defName="Shenanigans_Tribal_SacredDancer"]/workDisables</xpath>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Shenanigans_Tribal_SacredDancer"]/skillGains</xpath>
          <value><Construction>-2</Construction><Crafting>-2</Crafting></value>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>Defs/BackstoryDef[defName="Shenanigans_Tribal_AnimalSlayer"]/workDisables</xpath>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>Defs/BackstoryDef[defName="Shenanigans_Tribal_AnimalSlayer"]/skillGains</xpath>
          <value><Animals>-2</Animals></value>
        </li>
        <li Class="PatchOperationRemove">
          <xpath>Defs/BackstoryDef[defName="Shenanigans_Tribal_SpoiledChild"]/workDisables</xpath>
        </li>
      </operations>
    </match>
  </li></operations></Operation></Patch>

